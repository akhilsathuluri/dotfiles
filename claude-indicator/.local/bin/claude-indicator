#!/usr/bin/env python3
"""GNOME top bar indicator for Claude Code notifications.

Shows a dot + count when Claude Code sessions finish and are waiting for input.
Uses AppIndicator3 via the ubuntu-appindicators extension (pre-installed on Ubuntu 24.04).
"""

import os
import signal
import gi

gi.require_version("Gtk", "3.0")
gi.require_version("AppIndicator3", "0.1")
from gi.repository import Gtk, AppIndicator3, GLib

COUNTER_FILE = "/tmp/claude-ready-count"
LOCK_FILE = "/tmp/claude-ready.lock"
POLL_INTERVAL_MS = 1000


class ClaudeIndicator:
    def __init__(self):
        self.indicator = AppIndicator3.Indicator.new(
            "claude-indicator",
            "dialog-information-symbolic",
            AppIndicator3.IndicatorCategory.APPLICATION_STATUS,
        )
        self.indicator.set_status(AppIndicator3.IndicatorStatus.PASSIVE)

        menu = Gtk.Menu()

        dismiss_item = Gtk.MenuItem(label="Dismiss all")
        dismiss_item.connect("activate", self.dismiss)
        menu.append(dismiss_item)

        quit_item = Gtk.MenuItem(label="Quit")
        quit_item.connect("activate", self.quit)
        menu.append(quit_item)

        menu.show_all()
        self.indicator.set_menu(menu)

        GLib.timeout_add(POLL_INTERVAL_MS, self.check_counter)

    def get_count(self):
        try:
            with open(COUNTER_FILE, "r") as f:
                return int(f.read().strip())
        except (FileNotFoundError, ValueError):
            return 0

    def check_counter(self):
        count = self.get_count()
        if count > 0:
            self.indicator.set_status(AppIndicator3.IndicatorStatus.ACTIVE)
            self.indicator.set_label(f" {count}", "")
        else:
            self.indicator.set_status(AppIndicator3.IndicatorStatus.PASSIVE)
            self.indicator.set_label("", "")
        return True

    def dismiss(self, _):
        try:
            os.remove(COUNTER_FILE)
        except FileNotFoundError:
            pass
        self.indicator.set_status(AppIndicator3.IndicatorStatus.PASSIVE)
        self.indicator.set_label("", "")

    def quit(self, _):
        Gtk.main_quit()


def main():
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    ClaudeIndicator()
    Gtk.main()


if __name__ == "__main__":
    main()
