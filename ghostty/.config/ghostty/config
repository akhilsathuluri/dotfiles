# Theme
theme = iTerm2 Solarized Light
window-theme = light

# Font
font-family = JetBrainsMono Nerd Font
font-size = 12

# Cursor
# cursor-style = block
cursor-style-blink = false

# Hide mouse cursor while typing
mouse-hide-while-typing = true

# Selecting text auto-copies to clipboard
copy-on-select = clipboard

# Enables click-to-move cursor, command tracking, completion notifications
shell-integration = bash

# Extend content background color into padding for a seamless look
window-padding-color = extend

# Remove GTK titlebar for a cleaner look
gtk-titlebar = false

# URLs
link-url = true
