# Theme
theme = iTerm2 Solarized Light
window-theme = ghostty

# Font
font-family = JetBrainsMono Nerd Font
font-size = 10

# Cursor
cursor-style = block
cursor-style-blink = false

# Cursor trail (Neovide-like warp effect via custom shader)
# https://github.com/sahaj-b/ghostty-cursor-shaders
custom-shader = shaders/cursor_warp.glsl
custom-shader-animation = always

# Hide mouse cursor while typing
mouse-hide-while-typing = true

# Selecting text auto-copies to clipboard (suppress toast)
copy-on-select = clipboard
app-notifications = no-clipboard-copy

# Extend content background color into padding for a seamless look
window-padding-color = extend

# Distribute extra space as padding instead of leaving a gap
window-padding-balance = true

# Merge titlebar and tab bar into one compact row
gtk-titlebar-style = tabs
gtk-wide-tabs = false
gtk-custom-css = ~/.config/ghostty/style.css

# Tab navigation
keybind = alt+h=previous_tab
keybind = alt+l=next_tab

