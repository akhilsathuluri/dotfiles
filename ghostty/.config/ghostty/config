# Theme
theme = iTerm2 Solarized Light
window-theme = ghostty

# Font
font-family = JetBrainsMono Nerd Font
font-size = 12

# Cursor
# cursor-style = block
cursor-style-blink = false

# Hide mouse cursor while typing
mouse-hide-while-typing = true

# Selecting text auto-copies to clipboard
copy-on-select = clipboard

# Extend content background color into padding for a seamless look
window-padding-color = extend

# Merge titlebar and tab bar into one compact row
gtk-titlebar-style = tabs
gtk-wide-tabs = false
gtk-custom-css = ~/.config/ghostty/style.css

