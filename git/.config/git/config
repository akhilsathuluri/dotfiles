[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = zdiff3

[diff]
    algorithm = histogram
    colorMoved = default
    colorMovedWS = allow-indentation-change

[pager]
    blame = delta

[blame]
    coloring = highlightRecent
    date = relative

[push]
    autoSetupRemote = true
