[global_config]
  suppress_multiple_term_dialog = True
[keybindings]
  move_tab_right = ""
  move_tab_left = ""
  next_tab = <Alt>l
  prev_tab = <Alt>h
  layout_launcher = ""
[profiles]
  [[default]]
    scrollback_lines = 10000
    use_system_font = True
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
[plugins]
